{
  "Auth": {
    "Mode": "SelfJwt",
    "RequireHttpsMetadata": true,
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "ControleFinanceiro": "Information"
    }
  },
  "Observability": {
    "UseConsoleExporter": false
  },
  "FinanceAI": {
    "Enabled": true,
    "MaxTokens": 2048,
    "FastModel": "claude-haiku-4-5-20251001",
    "ReasoningModel": "claude-sonnet-4-6"
  },
  "FeatureFlags": {
    "recorrencia-automatica":  { "Enabled": true,  "Variant": "control" },
    "importacao-whatsapp":     { "Enabled": true,  "Variant": "control" },
    "conciliacao-automatica":  { "Enabled": false, "Variant": "control" },
    "dashboard-previsao":      { "Enabled": true,  "Variant": "control" },
    "limite-compartilhado":    { "Enabled": true,  "Variant": "control" },
    "compras-planejadas":      { "Enabled": true,  "Variant": "control" },
    "chaves-pix":              { "Enabled": true,  "Variant": "control" }
  }
}
